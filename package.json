{
  "name": "samsinn",
  "version": "0.6.0",
  "description": "Multi-agent room communication system with delivery modes, flows, muting, directed addressing, and MCP server",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run scripts/dev.ts",
    "dev:remote": "OLLAMA_URL=http://192.168.0.222:11434 bun run scripts/dev.ts",
    "start:remote": "OLLAMA_URL=http://192.168.0.222:11434 bun run src/main.ts",
    "build:css": "bunx @tailwindcss/cli -i src/ui/input.css -o src/ui/dist.css --minify",
    "dev:server": "bun --watch src/main.ts",
    "dev:css": "bunx @tailwindcss/cli -i src/ui/input.css -o src/ui/dist.css --watch",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test --filter '!Ollama'",
    "headless": "bun run src/main.ts --headless"
  },
  "keywords": ["agents", "multi-agent", "llm", "ollama", "communication", "rooms", "bun", "typescript"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelhil/samsinn"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/bun": "1.3.11",
    "tailwindcss": "^4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
