{
  "name": "samsinn",
  "version": "0.9.2",
  "description": "Multi-agent room communication system with multi-instance deploy, delivery modes, scripts (improv scenes), artifacts, MCP server, and bug reporting to GitHub",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run build:css && bun run src/main.ts",
    "start:remote": "OLLAMA_URL=http://192.168.0.222:11434 bun run start",
    "dev": "bun run scripts/dev.ts",
    "dev:remote": "OLLAMA_URL=http://192.168.0.222:11434 bun run scripts/dev.ts",
    "build:css": "bunx @tailwindcss/cli -i src/ui/input.css -o src/ui/dist.css --minify",
    "dev:server": "bun --watch src/main.ts",
    "dev:css": "bunx @tailwindcss/cli -i src/ui/input.css -o src/ui/dist.css --watch",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.ui.json",
    "check:server": "tsc --noEmit",
    "check:ui": "tsc --noEmit -p tsconfig.ui.json",
    "test": "bun test",
    "test:unit": "bun test -t '^(?!.*Ollama)'",
    "headless": "bun run src/main.ts --headless",
    "deploy": "bun run scripts/deploy.ts",
    "smoke": "bun run scripts/smoke-streaming.ts"
  },
  "keywords": ["agents", "multi-agent", "llm", "ollama", "communication", "rooms", "bun", "typescript"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelhil/samsinn"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/bun": "1.3.11",
    "tailwindcss": "^4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
