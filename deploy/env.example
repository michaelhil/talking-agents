# Sample environment file for /etc/samsinn/env (mode 0600, root:root).
#
# systemd reads this via EnvironmentFile=-/etc/samsinn/env. Lines starting
# with `#` are comments. No quotes around values.

# OPTIONAL — auth token shared with users. Leave UNSET for an open
# instance (anyone with the URL can use it; share-links via /?join=<id>
# work without a token prompt). Set when you want a token-gated sandbox.
# Generate with: head -c 24 /dev/urandom | base64 | tr -d '/+='
# SAMSINN_TOKEN=replace-me

# Ollama URL — point at your local Ollama or remove if you don't use it.
OLLAMA_URL=http://127.0.0.1:11434

# Cloud provider keys (optional — set the ones you've signed up for).
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# CEREBRAS_API_KEY=...
# MISTRAL_API_KEY=...
# SAMBANOVA_API_KEY=...

# Web search providers (only one needed). Required if SAMSINN_ENABLE_NETWORK_TOOLS=1
# and you want web_search to work. web_fetch / web_extract_json work without.
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=...
# GOOGLE_CSE_API_KEY=...
# GOOGLE_CSE_ID=...

# Feature flags — security knobs. Defaults are tuned per mode (deploy vs
# personal) but each can be forced via 1/0.
#
# SAMSINN_ENABLE_NETWORK_TOOLS — web_fetch / web_search / web_extract_json.
#   Default: deploy=off, personal=on. web_fetch can hit any URL the host
#   can reach (cloud metadata, private nets) so leave unset for sandbox.
# SAMSINN_ENABLE_NETWORK_TOOLS=1
#
# SAMSINN_ENABLE_CODEGEN — write_skill / write_tool. Lets agents drop
#   arbitrary TypeScript into ~/.samsinn/ and have it auto-loaded next
#   restart. Default: deploy=off, personal=on. Keep off on shared boxes.
# SAMSINN_ENABLE_CODEGEN=1
#
# SAMSINN_ENABLE_PACKS — install_pack / update_pack / uninstall_pack /
#   list_packs / list_available_packs. Different threat profile from
#   codegen: you trust the pack's source repo. Default: ON in both modes
#   so the operator gets pack management out of the box. Set to 0 to lock
#   the runtime to whatever pack content was on disk at boot.
# SAMSINN_ENABLE_PACKS=0

# Bug reporting — when set, the in-app "Report bug" entry POSTs to GitHub
# Issues using a fine-grained PAT (Issues: Read+Write on the target repo).
# The token is server-side only; the browser never sees it. Issues land in
# SAMSINN_GH_REPO (default: michaelhil/samsinn). For a public repo, the
# bug modal warns users that issues are public — tell invitees not to paste
# secrets or session tokens. See deploy/RUNBOOK.md §9b for setup.
# SAMSINN_GH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
# SAMSINN_GH_REPO=michaelhil/samsinn

# Pack registry sources — comma-separated list of GitHub orgs/users (lists
# their repos) or specific `owner/repo` paths. The Packs modal's
# "Available" section reads from this. Default: `samsinn-packs`.
# Owners ending in `-packs` (or literally `samsinn-packs`) include all
# their repos; other owners are filtered to repos prefixed `samsinn-pack-`
# so personal accounts don't surface unrelated repos as packs.
# SAMSINN_PACK_SOURCES=samsinn-packs

# Optional GitHub token for the registry's repo-listing calls. Distinct
# from SAMSINN_GH_TOKEN (which is fine-grained to one repo for bug
# reporting). Use a classic PAT with `public_repo` read scope, or a
# fine-grained PAT with broad public read access. Without this token the
# registry uses unauthenticated GitHub API at 60 req/hr (fine for a
# 5-min-cached sandbox).
# SAMSINN_PACK_REGISTRY_TOKEN=ghp_...

# First-run seeding — set to 0 to skip the demo room + Helper agent that
# get created in any fresh instance. Default: enabled (better first-touch
# UX for invitees).
# SAMSINN_SEED_EXAMPLE=0

# Model used by the seeded Helper agent. Pick something cheap that matches
# the providers you actually configured above. Examples:
#   gemini-2.5-flash-lite                (Gemini, cheapest)
#   claude-haiku-4-5                     (Anthropic, default)
#   groq:llama-3.3-70b-versatile         (Groq, fast)
# SAMSINN_SEED_MODEL=gemini-2.5-flash-lite
