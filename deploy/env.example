# Sample environment file for /etc/samsinn/env (mode 0600, root:root).
#
# systemd reads this via EnvironmentFile=-/etc/samsinn/env. Lines starting
# with `#` are comments. No quotes around values.

# REQUIRED in deploy mode — auth token shared with users.
# Generate with: head -c 24 /dev/urandom | base64 | tr -d '/+='
SAMSINN_TOKEN=replace-me

# Ollama URL — point at your local Ollama or remove if you don't use it.
OLLAMA_URL=http://127.0.0.1:11434

# Cloud provider keys (optional — set the ones you've signed up for).
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# CEREBRAS_API_KEY=...
# MISTRAL_API_KEY=...
# SAMBANOVA_API_KEY=...

# Web search providers (only one needed). Required if SAMSINN_ENABLE_NETWORK_TOOLS=1
# and you want web_search to work. web_fetch / web_extract_json work without.
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=...
# GOOGLE_CSE_API_KEY=...
# GOOGLE_CSE_ID=...

# Feature flags — leave UNSET on a public sandbox. Setting either to 1 lets
# users execute arbitrary TypeScript on the host (codegen) or hit arbitrary
# URLs from the host (network). Only flip these on a trusted authoring box.
# SAMSINN_ENABLE_CODEGEN=1
# SAMSINN_ENABLE_NETWORK_TOOLS=1

# Bug reporting — when set, the in-app "Report bug" entry POSTs to GitHub
# Issues using a fine-grained PAT (Issues: Read+Write on the target repo).
# The token is server-side only; the browser never sees it. Issues land in
# SAMSINN_GH_REPO (default: michaelhil/samsinn). For a public repo, the
# bug modal warns users that issues are public — tell invitees not to paste
# secrets or session tokens. See deploy/RUNBOOK.md §9b for setup.
# SAMSINN_GH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
# SAMSINN_GH_REPO=michaelhil/samsinn

# Pack registry sources — comma-separated list of GitHub orgs/users (lists
# their `samsinn-pack-*` repos) or specific `owner/repo` paths. The Packs
# modal's "Available" section reads from this. Default: `samsinn-packs`.
# SAMSINN_PACK_SOURCES=samsinn-packs,michaelhil/samsinn-pack-vatsim

# First-run seeding — set to 0 to skip the demo room + Helper agent that
# get created in any fresh instance. Default: enabled (better first-touch
# UX for invitees).
# SAMSINN_SEED_EXAMPLE=0

# Model used by the seeded Helper agent. Pick something cheap that matches
# the providers you actually configured above. Examples:
#   gemini-2.5-flash-lite                (Gemini, cheapest)
#   claude-haiku-4-5                     (Anthropic, default)
#   groq:llama-3.3-70b-versatile         (Groq, fast)
# SAMSINN_SEED_MODEL=gemini-2.5-flash-lite
