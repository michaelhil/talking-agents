# Sample environment file for /etc/samsinn/env (mode 0600, root:root).
#
# systemd reads this via EnvironmentFile=-/etc/samsinn/env. Lines starting
# with `#` are comments. No quotes around values.

# REQUIRED in deploy mode — auth token shared with users.
# Generate with: head -c 24 /dev/urandom | base64 | tr -d '/+='
SAMSINN_TOKEN=replace-me

# Ollama URL — point at your local Ollama or remove if you don't use it.
OLLAMA_URL=http://127.0.0.1:11434

# Cloud provider keys (optional — set the ones you've signed up for).
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# CEREBRAS_API_KEY=...
# MISTRAL_API_KEY=...
# SAMBANOVA_API_KEY=...

# Web search providers (only one needed). Required if SAMSINN_ENABLE_NETWORK_TOOLS=1
# and you want web_search to work. web_fetch / web_extract_json work without.
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=...
# GOOGLE_CSE_API_KEY=...
# GOOGLE_CSE_ID=...

# Feature flags — leave UNSET on a public sandbox. Setting either to 1 lets
# users execute arbitrary TypeScript on the host (codegen) or hit arbitrary
# URLs from the host (network). Only flip these on a trusted authoring box.
# SAMSINN_ENABLE_CODEGEN=1
# SAMSINN_ENABLE_NETWORK_TOOLS=1
